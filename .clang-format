# VS의 기본 스타일인 'Microsoft' 스타일을 기반으로 설정
BasedOnStyle: Chromium    

# 이 옵션을 false로 하면 더 이상 include 순서를 건드리지 않습니다.
SortIncludes: false

# 들여쓰기 설정 (4칸)
IndentWidth: 4
TabWidth: 4

# 탭 사용 여부 (VS처럼 실제 탭 문자를 쓰려면 Always, 공백 4칸을 쓰려면 Never)
UseTab: Always

# 중괄호를 다음 줄에 넣기 (VS 스타일의 핵심)
# BreakBeforeBraces: Allman

# 한 줄의 최대 길이
ColumnLimit: 120

# 포인터(*)나 참조(&) 기호를 타입 옆에 붙임 (int* a; 형태)
PointerAlignment: Left

# 클래스 접근 제어자(public, private) 들여쓰기 방지
AccessModifierOffset: -4